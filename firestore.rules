rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: properties
    //   - id: string (required)
    //   - name: string (required)
    //   - city: string (required)
    //   - country: string
    //   - bedrooms: number
    //   - max_guests: number
    //   - owner_name: string
    //   - created_at: timestamp
    //
    // Collection: metrics
    //   - property_id: string (required)
    //   - revenue: number
    //   - occupancy: number
    //   - adr: number
    //   - revpar: number
    //   - inventory_health: number
    //   - audit_score: number
    //   - cleaning_score: number
    //   - linen_score: number
    //   - maintenance_score: number
    //   - stock_days: number
    //   - lead_time: number
    //   - restock_flag: bool
    //   - cleaning_flag: bool
    //   - maintenance_flag: bool
    //   - updated_at: timestamp
    //
    // Collection: predictions
    //   - property_id: string (required)
    //   - stay_readiness: number
    //   - risk_level: string (LOW, HIGH, CRITICAL, STOCKOUT)
    //   - updated_at: timestamp
    //
    // Collection: orders
    //   - property_id: string (required)
    //   - item: string
    //   - quantity: number
    //   - status: string (pending, completed)
    //   - created_at: timestamp
    //
    // Collection: cleaning_tasks
    //   - property_id: string (required)
    //   - task_date: string (YYYY-MM-DD)
    //   - status: string (scheduled, completed)
    //   - created_at: timestamp
    //
    // Collection: maintenance_tasks
    //   - property_id: string (required)
    //   - issue: string
    //   - priority: string (low, medium, high)
    //   - status: string (open, completed)
    //   - created_at: timestamp
    //
    // Collection: users
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (admin, user)
    //   - created_at: timestamp
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "yashrajvansh008@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /properties/{propertyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /metrics/{metricId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // In a real app, only admins or authorized property managers
    }

    match /predictions/{propertyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Prediction logic will write here
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /cleaning_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /maintenance_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
  }
}

# SuperhostOS API — environment

# Server
PORT=4000
NODE_ENV=development

# Redis (REQUIRED) — queues, rate limiting, websocket state, booking locks
REDIS_URL=redis://localhost:6379

# Postgres (optional in dev, required in prod) — Drizzle / pg
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/superhostos

# Clerk (REQUIRED) — backend session/token verification
CLERK_SECRET_KEY=

# AI providers (optional) — consumed by the AI provider abstraction
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# DigitalOcean GradientAI Serverless Inference (optional) — powers AI guest
# replies. Without DO_INFERENCE_API_KEY the API returns a templated fallback.
DO_INFERENCE_API_KEY=
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_INFERENCE_MODEL=llama3.3-70b-instruct

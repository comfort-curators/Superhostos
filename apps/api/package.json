{
  "name": "@superhostos/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@clerk/backend": "^1.24.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "bullmq": "^5.34.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1",
    "@superhostos/db": "workspace:*",
    "@superhostos/shared": "workspace:*",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "@types/aws-lambda": "^8.10.147",
    "@types/pg": "^8.11.10"
  }
}

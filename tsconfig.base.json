{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@superhostos/shared": ["packages/shared/src/index.ts"],
      "@superhostos/db": ["packages/db/src/index.ts"],
      "@superhostos/api-contracts": ["packages/shared/src/contracts/index.ts"]
    }
  }
}

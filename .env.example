# API Configuration
API_PORT=8080
API_HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://superhostos:superhostos@localhost:5432/superhostos

# Redis (Cache & Queues)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Build & Deployment
TURBO_TEAM=superhostos
TURBO_TOKEN=your_turbo_token_here

# AWS Configuration (for Amplify)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Logging
LOG_LEVEL=info

# Email Service (Optional - AWS SES)
AWS_SES_REGION=us-east-1
AWS_SES_EMAIL_SOURCE=noreply@superhostos.com

# Authentication (Optional - Clerk)
CLERK_API_KEY=
CLERK_SECRET_KEY=

# API Keys
API_SECRET_KEY=your_secret_key_here
API_JWT_SECRET=your_jwt_secret_here
